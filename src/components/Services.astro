---
const services = [
  {
    n: "01",
    title: "Music sessions",
    tag: "you play. we record.",
    accent: "var(--pink)",
    body: "Tracking, overdubs, and mixdowns in a treated room. Bring the stems or build them here — we capture the take and hand you the master.",
    items: ["Vocal & instrument tracking", "Beat production", "Mix & master"],
  },
  {
    n: "02",
    title: "DJ sessions",
    tag: "plug. spin. record.",
    accent: "var(--teal)",
    body: "Record the set, film the set, stream the set. Bring your own controller or rent one of ours and drop in.",
    items: ["Live set capture", "Multi-cam video", "Stream-ready output"],
  },
  {
    n: "03",
    title: "Content shoots",
    tag: "plug. light. record.",
    accent: "var(--lime)",
    body: "Lit cyc, clean audio, and a setup dialed for short-form. Leave with a pile of cut-ready clips, edits back starting at 48 hours.",
    items: ["Lit on-brand sets", "Vertical & wide", "Cut-ready clips"],
  },
  {
    n: "04",
    title: "Podcasts",
    tag: "plug. mic. record.",
    accent: "var(--coral)",
    body: "Four mics, multi-cam, and a host who knows the gear. Sit down, talk, and leave with audio and video ready to publish.",
    items: ["Up to 4 guests", "Audio + video", "Edit-ready files"],
  },
];
---

<section class="section work" id="work">
  <div class="wrap">
    <div class="work__head">
      <p class="eyebrow" data-reveal>What we do</p>
      <h2 class="h2" data-reveal style="--d:80ms">
        one room.<br /><span class="outline-text">every</span> kind of record.
      </h2>
    </div>

    <div class="work__grid">
      {
        services.map((s, i) => (
          <article class="card" style={`--accent:${s.accent};--d:${i * 90}ms`} data-reveal>
            <div class="card__top">
              <span class="card__n">{s.n}</span>
              <svg class="card__wave" viewBox="0 0 100 30" fill="none" aria-hidden="true">
                <path
                  d="M2 22 C10 23 13 12 20 12 C27 12 28 24 36 24 C44 24 45 8 53 8 C61 8 62 20 70 18 C80 16 88 8 98 6"
                  stroke="var(--accent)"
                  stroke-width="4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </div>
            <p class="card__tag">{s.tag}</p>
            <h3 class="card__title">{s.title}</h3>
            <p class="card__body">{s.body}</p>
            <ul class="card__list">
              {s.items.map((it) => (
                <li>{it}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .work__head { margin-bottom: clamp(40px, 6vw, 80px); }
  .work__head .h2 { margin-top: 0.5em; }

  .work__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(14px, 1.6vw, 22px);
  }

  .card {
    position: relative;
    padding: clamp(26px, 3vw, 44px);
    border: 1px solid var(--line);
    border-radius: 22px;
    background: linear-gradient(180deg, var(--surface), var(--ink-2));
    overflow: hidden;
    transition: border-color 0.5s var(--ease), transform 0.5s var(--ease);
  }
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 80% at 80% 0%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 60%);
    opacity: 0;
    transition: opacity 0.5s var(--ease);
  }
  .card:hover { transform: translateY(-6px); border-color: color-mix(in srgb, var(--accent) 55%, transparent); }
  .card:hover::before { opacity: 1; }

  .card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.6rem;
  }
  .card__n {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--faint);
  }
  .card__wave { width: 84px; height: 26px; opacity: 0.9; }

  .card__tag {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--accent);
    margin-bottom: 0.6rem;
  }
  .card__title {
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    text-transform: lowercase;
    margin-bottom: 0.7rem;
  }
  .card__body { color: var(--muted); font-size: 0.98rem; margin-bottom: 1.5rem; }
  .card__list { list-style: none; display: flex; flex-wrap: wrap; gap: 8px; }
  .card__list li {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text);
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--line);
    border-radius: 100px;
  }

  @media (max-width: 720px) {
    .work__grid { grid-template-columns: 1fr; }
  }
</style>
