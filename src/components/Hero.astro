---
import Icon from "./Icon.astro";
---

<section class="hero" id="home">
  <div class="hero__bg" aria-hidden="true">
    <span class="hero__ghost">954</span>
    <span class="hero__blob hero__blob--1"></span>
    <span class="hero__blob hero__blob--2"></span>
  </div>

  <div class="wrap hero__grid">
    <div class="hero__col">
      <p class="eyebrow" data-reveal>Fort Lauderdale · the 954</p>

      <h1 class="hero__title display">
        <span data-reveal style="--d:80ms">you <span class="pink">play.</span></span>
        <span data-reveal style="--d:200ms">we record.</span>
      </h1>

      <p class="lead hero__lead" data-reveal style="--d:320ms">
        A creative studio built for sound and screen. Roll in with an idea — walk out
        with a master, a reel, an episode. You bring the energy. We catch every frame of it.
      </p>

      <div class="hero__cta" data-reveal style="--d:420ms">
        <a href="#book" class="btn" data-magnetic>
          Book a session
          <svg width="15" height="15" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a href="#work" class="btn btn--ghost">See what we do</a>
      </div>

      <dl class="hero__meta" data-reveal style="--d:520ms">
        <div><dt>Call</dt><dd><a href="tel:+19544661698">954.466.1698</a></dd></div>
        <div><dt>Hours</dt><dd>By appointment · 7 days</dd></div>
        <div><dt>Setup</dt><dd>Plug &amp; play ready</dd></div>
      </dl>
    </div>

    <div class="hero__mark" data-reveal style="--d:260ms" aria-hidden="true">
      <span class="hero__icon"><Icon animated /></span>
      <div class="eq">
        {Array.from({ length: 7 }).map((_, i) => <span style={`--i:${i}`}></span>)}
      </div>
    </div>
  </div>

  <a href="#work" class="hero__scroll" aria-label="Scroll to content">
    <span>scroll</span>
    <svg width="12" height="40" viewBox="0 0 12 40" fill="none"><path d="M6 0V38M6 38L1 32M6 38L11 32" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" /></svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: 84px;
    overflow: hidden;
  }
  .hero__bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .hero__ghost {
    position: absolute;
    right: -2vw;
    bottom: -8vh;
    font-size: clamp(20rem, 46vw, 56rem);
    font-weight: 800;
    line-height: 0.7;
    letter-spacing: -0.06em;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.05);
    user-select: none;
  }
  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.5;
  }
  .hero__blob--1 {
    width: 46vw; height: 46vw; max-width: 620px; max-height: 620px;
    top: -16%; left: -10%;
    background: radial-gradient(circle, rgba(237, 49, 142, 0.5), transparent 65%);
  }
  .hero__blob--2 {
    width: 38vw; height: 38vw; max-width: 520px; max-height: 520px;
    bottom: -22%; right: 6%;
    background: radial-gradient(circle, rgba(88, 197, 201, 0.22), transparent 65%);
  }

  .hero__grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.35fr 0.65fr;
    align-items: center;
    gap: clamp(24px, 5vw, 64px);
    width: 100%;
  }
  .hero__title { margin: 0.5em 0 0.42em; }
  .hero__title span { display: block; }
  .hero__lead { margin-bottom: 2.4rem; }

  .hero__cta { display: flex; flex-wrap: wrap; gap: 14px; }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(20px, 4vw, 52px);
    margin-top: 3rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--line);
  }
  .hero__meta dt {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--faint);
    margin-bottom: 0.4rem;
  }
  .hero__meta dd { font-weight: 700; font-size: 1.05rem; }
  .hero__meta a:hover { color: var(--pink); }

  .hero__mark {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
  }
  .hero__icon {
    display: block;
    width: min(34vw, 300px);
    color: #fff;
    animation: float 7s ease-in-out infinite;
  }
  @keyframes float { 50% { transform: translateY(-14px); } }

  .eq { display: flex; align-items: flex-end; gap: 6px; height: 46px; }
  .eq span {
    width: 6px;
    border-radius: 6px;
    background: linear-gradient(var(--teal), var(--pink));
    animation: eq 1.1s ease-in-out infinite;
    animation-delay: calc(var(--i) * -0.18s);
    height: 30%;
  }
  @keyframes eq { 0%, 100% { height: 20%; } 50% { height: 100%; } }

  .hero__scroll {
    position: absolute;
    left: 50%;
    bottom: 26px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 3;
    color: var(--faint);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }
  .hero__scroll svg { animation: bob 2.2s ease-in-out infinite; }
  @keyframes bob { 50% { transform: translateY(6px); } }

  @media (max-width: 980px) {
    .hero__grid { grid-template-columns: 1fr; }
    .hero__mark { order: -1; flex-direction: row; justify-content: flex-start; gap: 22px; }
    .hero__icon { width: 120px; }
    .hero__scroll { display: none; }
  }
</style>
