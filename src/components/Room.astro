---
const stats = [
  { k: "954", v: "our area code, our sound" },
  { k: "4K", v: "Sony multi-cam on every session" },
  { k: "00:00", v: "setup time — it's already patched" },
  { k: "7", v: "days a week, by appointment" },
];
const gear = [
  "4K Sony cameras",
  "Rode podcast hardware",
  "Shure microphones",
  "QSC audio system",
  "Cue-mixed headphone sends",
  "Bring your controller — or rent ours",
];
---

<section class="section room" id="room">
  <div class="wrap room__grid">
    <div class="room__copy">
      <p class="eyebrow" data-reveal>The room</p>
      <h2 class="h2" data-reveal style="--d:80ms">
        a space that's<br />already <span class="pink">pressed&nbsp;record.</span>
      </h2>
      <p class="lead" data-reveal style="--d:160ms">
        No tangle of cables, no "give us an hour to set up." The room stays patched and
        ready so the moment you're inspired, we're already rolling. Sound that's tight,
        light that's flattering, and a host behind the glass who actually knows the gear.
      </p>

      <ul class="room__gear" data-reveal style="--d:240ms">
        {gear.map((g) => <li>{g}</li>)}
      </ul>
    </div>

    <figure class="room__visual" data-reveal style="--d:160ms">
      <div class="render">
        <img
          src="/img/studio-room-render.jpg"
          alt="3D rendering of the studio954 podcast lounge — twin chairs, dual boom-arm mics and the logo on screen under an arched accent light"
          width="1402"
          height="1122"
          loading="lazy"
          decoding="async"
        />
        <span class="render__badge">3D render</span>
      </div>
      <figcaption class="render__cap">
        A 3D rendering of our studio build-out plans. Real photos coming soon.
      </figcaption>
    </figure>
  </div>

  <div class="room__stats wrap">
    {
      stats.map((s, i) => (
        <div class="stat" data-reveal style={`--d:${i * 90}ms`}>
          <span class="stat__k">{s.k}</span>
          <span class="stat__v">{s.v}</span>
        </div>
      ))
    }
  </div>
</section>

<style>
  .room__grid {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: clamp(36px, 6vw, 90px);
    align-items: center;
  }
  .room__copy .h2 { margin: 0.5em 0 0.7em; }
  .room__gear {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 2rem;
  }
  .room__gear li {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--muted);
    padding: 0.5rem 1rem;
    border: 1px solid var(--line);
    border-radius: 100px;
    transition: border-color 0.4s var(--ease), color 0.4s var(--ease);
  }
  .room__gear li:hover { color: var(--text); border-color: var(--pink); }

  /* real render of the studio build-out */
  .room__visual { margin: 0; }
  .render {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--line-strong);
    box-shadow: 0 50px 120px -40px rgba(0, 0, 0, 0.9), inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .render::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 90% at 50% 120%, rgba(237, 49, 142, 0.18), transparent 55%);
    pointer-events: none;
  }
  .render img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.8s var(--ease);
  }
  .room__visual:hover .render img { transform: scale(1.04); }
  .render__badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #fff;
    padding: 0.4rem 0.7rem;
    border-radius: 100px;
    background: rgba(11, 11, 12, 0.55);
    border: 1px solid var(--line-strong);
    backdrop-filter: blur(8px);
  }
  .render__cap {
    margin-top: 0.9rem;
    font-size: 0.8rem;
    color: var(--faint);
    text-align: center;
  }

  .room__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(16px, 2vw, 28px);
    margin-top: clamp(56px, 8vw, 100px);
    padding-top: clamp(36px, 5vw, 56px);
    border-top: 1px solid var(--line);
  }
  .stat { display: flex; flex-direction: column; gap: 0.5rem; }
  .stat__k {
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1;
    background: linear-gradient(120deg, #fff, var(--pink));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .stat__v { font-size: 0.88rem; color: var(--muted); max-width: 22ch; }

  @media (max-width: 900px) {
    .room__grid { grid-template-columns: 1fr; }
    .room__visual { order: -1; }
    .room__stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>
