---
import Icon from "./Icon.astro";
const stats = [
  { k: "954", v: "our area code, our sound" },
  { k: "4K", v: "multi-cam video on every session" },
  { k: "00:00", v: "setup time — it's already patched" },
  { k: "7", v: "days a week, by appointment" },
];
const gear = [
  "Treated live room",
  "Neumann + Shure mics",
  "Universal Audio chain",
  "4K cinema cameras",
  "Lit cyc wall",
  "DJ booth — CDJs & controllers",
  "Cue-mixed headphone sends",
  "Stream encoder",
];
---

<section class="section room" id="room">
  <div class="wrap room__grid">
    <div class="room__copy">
      <p class="eyebrow" data-reveal>The room</p>
      <h2 class="h2" data-reveal style="--d:80ms">
        a space that's<br />already <span class="pink">pressed&nbsp;record.</span>
      </h2>
      <p class="lead" data-reveal style="--d:160ms">
        No tangle of cables, no "give us an hour to set up." The room stays patched and
        ready so the moment you're inspired, we're already rolling. Sound that's tight,
        light that's flattering, and a host behind the glass who actually knows the gear.
      </p>

      <ul class="room__gear" data-reveal style="--d:240ms">
        {gear.map((g) => <li>{g}</li>)}
      </ul>
    </div>

    <div class="room__visual" data-reveal style="--d:160ms" aria-hidden="true">
      <div class="screen">
        <div class="screen__glow"></div>
        <Icon class="screen__icon" />
        <span class="screen__word">studio954</span>
        <span class="screen__tag">you play. we record.</span>
        <div class="screen__bars">
          {Array.from({ length: 28 }).map((_, i) => <span style={`--i:${i}`}></span>)}
        </div>
      </div>
    </div>
  </div>

  <div class="room__stats wrap">
    {
      stats.map((s, i) => (
        <div class="stat" data-reveal style={`--d:${i * 90}ms`}>
          <span class="stat__k">{s.k}</span>
          <span class="stat__v">{s.v}</span>
        </div>
      ))
    }
  </div>
</section>

<style>
  .room__grid {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: clamp(36px, 6vw, 90px);
    align-items: center;
  }
  .room__copy .h2 { margin: 0.5em 0 0.7em; }
  .room__gear {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 2rem;
  }
  .room__gear li {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--muted);
    padding: 0.5rem 1rem;
    border: 1px solid var(--line);
    border-radius: 100px;
    transition: border-color 0.4s var(--ease), color 0.4s var(--ease);
  }
  .room__gear li:hover { color: var(--text); border-color: var(--pink); }

  /* CSS "screen" — evokes the brand mockup without a stock photo */
  .room__visual { perspective: 1400px; }
  .screen {
    position: relative;
    aspect-ratio: 16 / 11;
    border-radius: 20px;
    border: 1px solid var(--line-strong);
    background: radial-gradient(120% 120% at 50% 0%, #1b1b1e, #0a0a0b 70%);
    box-shadow: 0 50px 120px -40px rgba(0, 0, 0, 0.9), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    overflow: hidden;
    transform: rotateY(-9deg) rotateX(3deg);
    transition: transform 0.7s var(--ease);
  }
  .room__visual:hover .screen { transform: rotateY(0deg) rotateX(0deg); }
  .screen__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(60% 50% at 50% 42%, rgba(237, 49, 142, 0.22), transparent 70%);
  }
  .screen__icon { width: 26%; color: #fff; position: relative; }
  .screen__word {
    font-weight: 800;
    font-size: clamp(1.4rem, 3.4vw, 2.2rem);
    letter-spacing: -0.05em;
    margin-top: 0.4rem;
    position: relative;
  }
  .screen__tag {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--muted);
    position: relative;
  }
  .screen__bars {
    position: absolute;
    inset: auto 0 0 0;
    height: 30%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 3px;
    padding: 0 6%;
    opacity: 0.5;
  }
  .screen__bars span {
    flex: 1;
    max-width: 7px;
    border-radius: 4px 4px 0 0;
    background: linear-gradient(var(--pink), transparent);
    height: 30%;
    animation: wave 1.4s ease-in-out infinite;
    animation-delay: calc(var(--i) * -0.08s);
  }
  @keyframes wave { 0%, 100% { height: 14%; } 50% { height: 90%; } }

  .room__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(16px, 2vw, 28px);
    margin-top: clamp(56px, 8vw, 100px);
    padding-top: clamp(36px, 5vw, 56px);
    border-top: 1px solid var(--line);
  }
  .stat { display: flex; flex-direction: column; gap: 0.5rem; }
  .stat__k {
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1;
    background: linear-gradient(120deg, #fff, var(--pink));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .stat__v { font-size: 0.88rem; color: var(--muted); max-width: 22ch; }

  @media (max-width: 900px) {
    .room__grid { grid-template-columns: 1fr; }
    .room__visual { order: -1; }
    .room__stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>
