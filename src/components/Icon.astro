---
/**
 * studio954 power-mark — recreated as inline SVG so it can be themed
 * (white ring on dark) and animated. Power button = the spark / start;
 * pink rounded wave = the "play" energy.
 */
interface Props {
  class?: string;
  ring?: string;
  wave?: string;
  animated?: boolean;
}
const { class: cls = "", ring = "currentColor", wave = "var(--pink)", animated = false } = Astro.props;
---

<svg
  class={`s9-icon ${animated ? "is-animated" : ""} ${cls}`}
  viewBox="0 0 100 100"
  fill="none"
  role="img"
  aria-label="studio954 power mark"
  xmlns="http://www.w3.org/2000/svg"
>
  <g stroke={ring} stroke-width="8.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M65.9 22 A34 34 0 1 1 34.1 22" fill="none" />
    <line x1="50" y1="15" x2="50" y2="40" />
  </g>
  <path
    class="s9-wave"
    d="M14 71 C20 72 24 67 30 62 C35 58 39 67 44 67 C50 67 51 53 57 53 C62 53 63 63 68 60 C74 57 79 46 87 42"
    fill="none"
    stroke={wave}
    stroke-width="7.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>

<style>
  .s9-icon { width: 100%; height: auto; overflow: visible; }
  .s9-wave { filter: drop-shadow(0 0 14px rgba(237, 49, 142, 0.45)); }

  .is-animated .s9-wave {
    stroke-dasharray: 170;
    stroke-dashoffset: 170;
    animation: s9-draw 1.6s var(--ease, cubic-bezier(0.16, 1, 0.3, 1)) 0.3s forwards;
  }
  @keyframes s9-draw {
    to { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .is-animated .s9-wave { stroke-dashoffset: 0; animation: none; }
  }
</style>
