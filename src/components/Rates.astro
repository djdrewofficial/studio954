---
const tiers = [
  {
    name: "Hourly",
    price: "Custom quote",
    note: "Quick sessions & top-ups",
    feat: ["Engineer included", "Audio or video", "Raw files same day"],
    accent: "var(--teal)",
  },
  {
    name: "Half day",
    price: "Custom quote",
    note: "4 hours · the sweet spot",
    feat: ["Engineer + host", "Multi-cam video", "1 edited deliverable", "Priority booking"],
    accent: "var(--pink)",
    featured: true,
  },
  {
    name: "Full day",
    price: "Custom quote",
    note: "8 hours · go all in",
    feat: ["Full crew", "Multi-cam + lit set", "Batch of edited clips", "Stream-ready output"],
    accent: "var(--lime)",
  },
];
---

<section class="section rates" id="rates">
  <div class="wrap">
    <div class="rates__head">
      <p class="eyebrow" data-reveal>Rates</p>
      <h2 class="h2" data-reveal style="--d:80ms">pick your <span class="pink">window.</span></h2>
      <p class="lead" data-reveal style="--d:140ms">
        Every session is built around what you're making, so final pricing comes with your quote.
        Here's how the time shakes out.
      </p>
    </div>

    <div class="rates__grid">
      {
        tiers.map((t, i) => (
          <article
            class={`tier ${t.featured ? "tier--featured" : ""}`}
            style={`--accent:${t.accent};--d:${i * 100}ms`}
            data-reveal
          >
            {t.featured && <span class="tier__flag">most booked</span>}
            <h3 class="tier__name">{t.name}</h3>
            <p class="tier__price">{t.price}</p>
            <p class="tier__note">{t.note}</p>
            <ul class="tier__feat">
              {t.feat.map((f) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="#book" class={`btn ${t.featured ? "" : "btn--ghost"} tier__btn`}>Get a quote</a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .rates__head { max-width: 60ch; margin-bottom: clamp(40px, 6vw, 72px); }
  .rates__head .h2 { margin: 0.5em 0 0.6em; }

  .rates__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(14px, 1.6vw, 22px);
    align-items: stretch;
  }

  .tier {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: clamp(28px, 3vw, 40px);
    border: 1px solid var(--line);
    border-radius: 22px;
    background: var(--surface);
    transition: transform 0.5s var(--ease), border-color 0.5s var(--ease);
  }
  .tier:hover { transform: translateY(-6px); border-color: color-mix(in srgb, var(--accent) 55%, transparent); }
  .tier--featured {
    background: linear-gradient(180deg, color-mix(in srgb, var(--pink) 12%, var(--surface)), var(--ink-2));
    border-color: color-mix(in srgb, var(--pink) 45%, transparent);
  }
  .tier__flag {
    position: absolute;
    top: -11px;
    left: clamp(28px, 3vw, 40px);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: var(--pink);
    color: #fff;
    padding: 0.32rem 0.7rem;
    border-radius: 100px;
  }
  .tier__name {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .tier__price {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0.6rem 0 0.2rem;
  }
  .tier__note { color: var(--muted); font-size: 0.9rem; margin-bottom: 1.6rem; }
  .tier__feat { list-style: none; display: grid; gap: 0.7rem; margin-bottom: 2rem; }
  .tier__feat li { display: flex; align-items: center; gap: 0.6rem; font-size: 0.92rem; }
  .tier__feat svg { flex: none; }
  .tier__btn { margin-top: auto; justify-content: center; }

  @media (max-width: 820px) {
    .rates__grid { grid-template-columns: 1fr; max-width: 460px; margin-inline: auto; }
  }
</style>
